{
  "expo": {
    "name": "Gánh Phim",
    "slug": "ganh-phim",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/iconapp.png",
    "scheme": "myapp",
    "userInterfaceStyle": "dark",
    "backgroundColor": "#000000",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/iconapp.png",
      "resizeMode": "contain",
      "backgroundColor": "#07113A"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "backgroundColor": "#07113A",
      "navigationBarColor": "#101E53",
      "package": "com.tinph1830.ganhphim"
    },
    "web": {
      "bundler": "metro",
      "output": "single",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-web-browser"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "1ca26c49-f22d-4522-941e-76debe8eecca"
      }
    }
  }
}
