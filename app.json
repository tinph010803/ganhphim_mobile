{
  "expo": {
    "name": "Gánh Phim",
    "slug": "ganh-phim",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "myapp",
    "userInterfaceStyle": "dark",
    "backgroundColor": "#07113A",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "backgroundColor": "#07113A",
      "navigationBarColor": "#101E53"
    },
    "web": {
      "bundler": "metro",
      "output": "single",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": ["expo-router", "expo-font", "expo-web-browser"],
    "experiments": {
      "typedRoutes": true
    }
  }
}
